# ============================================================
# Shadow AI Sentinel — Environment Configuration
# Copy to .env and fill in values
# NEVER commit .env to git
# ============================================================

# --- Database ---
POSTGRES_PASSWORD=change-me-in-production
REDIS_PASSWORD=change-me-in-production

# --- Proxy Service ---
JWT_SECRET=change-me-to-random-64-char-string
ENVIRONMENT=development

# --- DLP Enforcement ---
# LEARNING_MODE: set to "true" to detect but never block/redact (observation only).
# Default: false (enforcing mode — PII is blocked/redacted).
LEARNING_MODE=false

# --- API Authentication ---
# API_KEY: if set, all /api/v1 and /proxy requests require Authorization: Bearer <key>.
# Leave empty for open access in development.
API_KEY=
DEFAULT_ORG_ID=dev-org

# --- GCP (Phase 2 - leave blank until ready) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_KEY=

# --- External LLM Keys (Phase 2 - for cloud proxy mode) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_KEY=

# --- On-Prem LLM ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# --- Alerts (Phase 3) ---
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- Domain ---
PROXY_DOMAIN=
DASHBOARD_DOMAIN=
